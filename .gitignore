# ============================================================
# Datasets - never commit image data to git
# ============================================================
Datasets/
*.zip

# ============================================================
# Helper Scripts
# ============================================================
helper scripts/

# ============================================================
# Generated CSV files (track frozen split artifacts, ignore the rest)
# ============================================================
CSV/*
!CSV/plantvillage_multiclass_labels.csv
!CSV/plantvillage_train.csv
!CSV/plantvillage_val.csv
!CSV/plantvillage_test.csv

# ============================================================
# Saved model weights (too large for git)
# ============================================================
models/*.pth
models/*.pt
models/*.ckpt

# ============================================================
# Markdown / resolved files
# ============================================================
*.md.resolved
*.resolved

# ===============
# Jupyter / Python artefacts
# ===============
.ipynb_checkpoints/
* (for context).ipynb
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Track only canonical manifest; ignore timestamped variants
results/split_manifests/*.json
!results/split_manifests/latest_split_manifest.json

# Track only latest integrity artifacts; ignore timestamped variants
results/integrity_reports/*.json
results/integrity_reports/*.txt
!results/integrity_reports/latest_integrity_report.json
!results/integrity_reports/latest_integrity_report.txt

# Track only latest baseline smoke artifacts
results/baseline_smoke/sample_splits/*.csv
results/baseline_smoke/metrics_snapshot_*.json
results/baseline_smoke/confusion_matrix_*.json
results/baseline_smoke/confusion_matrix_*.png
!results/baseline_smoke/latest_metrics_snapshot.json
!results/baseline_smoke/latest_experiment_log.json
!results/baseline_smoke/latest_confusion_matrix.json
!results/baseline_smoke/latest_confusion_matrix.png

# Track only latest colab smoke artifacts
results/colab_smoke/*.json
results/colab_smoke/*.txt
!results/colab_smoke/latest_colab_smoke.json
!results/colab_smoke/latest_colab_smoke.txt

# Track only latest stability check artifacts
results/stability_checks/*.json
results/stability_checks/*.txt
!results/stability_checks/latest_stability_check.json
!results/stability_checks/latest_stability_check.txt

# Keep baseline "latest" artifact copies; ignore raw experiment log fan-out
results/experiment_logs/*.json

# ============================================================
# IDE / OS / Documentation
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
Markdown Files/
FYP/
Curriculum Vitae/
